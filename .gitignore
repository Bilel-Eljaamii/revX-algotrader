# ==============================================================================
# Ultimate .gitignore for Full-Stack Node.js Monorepo (Vue + Vite + TS Backend)
# ==============================================================================

# ------------------------------------------------------------------------------
# Dependencies
# ------------------------------------------------------------------------------
node_modules/
jspm_packages/
.npm/

# ------------------------------------------------------------------------------
# Build Outputs & Artifacts
# ------------------------------------------------------------------------------
dist/
dist-ssr/
build/
out/
.vite/
.output/
.nuxt/
.vercel/
.cache/

# ------------------------------------------------------------------------------
# Testing & Coverage
# ------------------------------------------------------------------------------
coverage/
.nyc_output/
junit.xml
test-results/
.vitest/

# ------------------------------------------------------------------------------
# Database & State (Crucial to ignore for Revolut-X Grid Bot)
# ------------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-shm
*.db-wal

# ------------------------------------------------------------------------------
# Environment Variables & Secrets
# ------------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
credentials.json

# ------------------------------------------------------------------------------
# Logs & Debugging
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.db*
*.sqlite*
*.db-journal
*.db-shm
*.db-wal

# ------------------------------------------------------------------------------
# OS & System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# IDEs & Editor Configuration
# ------------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.vim/
.project
.settings/

# ------------------------------------------------------------------------------
# AI Assistants / Agent Workspaces
# ------------------------------------------------------------------------------
.gemini/
.cursor/
.cline/
.windsurf/
.agentic-qe/
.claude/
.claude-flow/

# ------------------------------------------------------------------------------
# Optional NPM & TS specific
# ------------------------------------------------------------------------------
.npmrc
.tsbuildinfo
.eslintcache

# ------------------------------------------------------------------------------
# Project Specific
# ------------------------------------------------------------------------------
backend/target/*
# backend/scratch/*
backend/node_modules/*
backend/organize.py
frontend/node_modules/*
frontend/dist/*
.antigravitycli/*
