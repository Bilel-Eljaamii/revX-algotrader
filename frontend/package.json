{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{js,ts,vue,css,html,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,vue,css,html,json,md}\"",
    "lint": "eslint \"src/**/*.{js,ts,vue}\"",
    "lint:fix": "eslint \"src/**/*.{js,ts,vue}\" --fix",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:fix": "vue-tsc --noEmit --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/chart.js": "^2.9.41",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "eslint-plugin-vue": "^10.9.1",
    "happy-dom": "^20.10.6",
    "vite": "^8.0.12",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.2.8"
  }
}